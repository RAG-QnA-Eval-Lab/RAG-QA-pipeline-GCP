# Airflow 설정 오버라이드 — 환경변수로 적용
# AIRFLOW__SECTION__KEY 형식으로 export

# === Core ===
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DEFAULT_TIMEZONE=Asia/Seoul
AIRFLOW__CORE__MAX_ACTIVE_RUNS_PER_DAG=1

# === Database (PostgreSQL) ===
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow

# === Webserver ===
AIRFLOW__WEBSERVER__WEB_SERVER_PORT=8080
AIRFLOW__WEBSERVER__RBAC=True
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=False
AIRFLOW__WEBSERVER__SECRET_KEY=CHANGE_ME_IN_PRODUCTION

# === Scheduler ===
AIRFLOW__SCHEDULER__MIN_FILE_PROCESS_INTERVAL=60

# === Logging ===
AIRFLOW__LOGGING__BASE_LOG_FOLDER=/opt/airflow/logs
AIRFLOW__LOGGING__REMOTE_LOGGING=False
