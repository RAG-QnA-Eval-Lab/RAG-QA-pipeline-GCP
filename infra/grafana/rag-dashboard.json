{
  "title": "RAG Youth Policy Phase 6 Operations",
  "uid": "rag-youth-policy-phase6",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["rag", "cloud-run", "phase6"],
  "templating": {"list": []},
  "time": {"from": "now-6h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Cloud Run API - Request Count / Latency",
      "datasource": {"type": "stackdriver", "uid": "gcp-cloud-monitoring"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {"refId": "A", "metricType": "run.googleapis.com/request_count", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_RATE", "crossSeriesReducer": "REDUCE_SUM", "groupBys": ["resource.label.service_name"]},
        {"refId": "B", "metricType": "run.googleapis.com/request_latencies", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_DELTA", "crossSeriesReducer": "REDUCE_PERCENTILE_95", "groupBys": ["resource.label.service_name"]}
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RAG Pipeline Latency (retrieval/generation)",
      "datasource": {"type": "stackdriver", "uid": "gcp-cloud-monitoring"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {"refId": "A", "metricType": "custom.googleapis.com/rag/retrieval_latency_ms", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_MEAN", "crossSeriesReducer": "REDUCE_MEAN", "groupBys": ["metric.label.strategy"]},
        {"refId": "B", "metricType": "custom.googleapis.com/rag/generation_latency_ms", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_MEAN", "crossSeriesReducer": "REDUCE_MEAN", "groupBys": ["metric.label.model"]}
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "LLM Cost / Tokens",
      "datasource": {"type": "stackdriver", "uid": "gcp-cloud-monitoring"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {"refId": "A", "metricType": "custom.googleapis.com/rag/tokens_used", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_SUM", "crossSeriesReducer": "REDUCE_SUM", "groupBys": ["metric.label.model"]},
        {"refId": "B", "metricType": "custom.googleapis.com/rag/estimated_cost_usd", "alignmentPeriod": "60s", "perSeriesAligner": "ALIGN_SUM", "crossSeriesReducer": "REDUCE_SUM", "groupBys": ["metric.label.model"]}
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "MongoDB api_usage_logs (model cost tracker)",
      "datasource": {"type": "mongodb-datasource", "uid": "mongodb"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {"refId": "A", "query": "db.api_usage_logs.aggregate([{ $match: { timestamp: { $gte: '$__from' } } }, { $group: { _id: '$model', requests: { $sum: 1 }, tokens: { $sum: { $add: ['$tokens_in', '$tokens_out'] } }, cost_usd: { $sum: '$cost_usd' }, avg_latency_ms: { $avg: '$latency_ms' } } }, { $sort: { cost_usd: -1 } }])"}
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Data Ingestion Freshness",
      "datasource": {"type": "mongodb-datasource", "uid": "mongodb"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [
        {"refId": "A", "query": "db.ingestion_logs.aggregate([{ $sort: { created_at: -1 } }, { $group: { _id: '$source', last_run: { $first: '$created_at' }, status: { $first: '$status' }, collected: { $first: '$collected_count' }, valid: { $first: '$valid_count' } } }, { $sort: { last_run: -1 } }])"}
      ]
    }
  ]
}
